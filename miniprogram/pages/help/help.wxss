/* 帮助与反馈 ⑩ */

.page {
  width: 100%;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--bg-page);
}

/* ============ 自定义导航栏 ============ */
.nav-bar { width: 100%; flex-shrink: 0; }
.nav-bar-content {
  display: flex;
  align-items: center;
  padding: 0 48rpx;
  justify-content: space-between;
}
.nav-back {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--ink);
  background: transparent;
}
.back-icon {
  width: 44rpx;
  height: 44rpx;
  background: currentColor;
  -webkit-mask: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='black' stroke-width='2.2' stroke-linecap='round' stroke-linejoin='round'><polyline points='15 18 9 12 15 6'/></svg>") no-repeat center / contain;
}
.nav-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--ink-2);
}

/* ============ 主体滚动区 ============ */
.subpage-list {
  flex: 1;
  width: 100%;
  box-sizing: border-box;
}
.list-inner {
  padding: 8rpx 40rpx 48rpx;
  display: flex;
  flex-direction: column;
}

/* ============ Section title ============ */
.list-section-title {
  font-size: 22rpx;
  color: var(--ink-3);
  font-weight: 700;
  letter-spacing: 1.2rpx;
  text-transform: uppercase;
  margin: 16rpx 4rpx 18rpx;
}
.section-feedback {
  margin-top: 36rpx;
}

/* ============ FAQ ============ */
.faq-item {
  background: var(--bg-card);
  border: 1rpx solid var(--line);
  border-radius: 28rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 16rpx;
  transition: border-color .25s;
}
.faq-item.open {
  border-color: var(--ink-4);
}
.faq-question {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}
.faq-q-text {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--ink);
  line-height: 1.5;
  flex: 1;
}
.faq-arrow {
  width: 28rpx;
  height: 28rpx;
  background: var(--ink-3);
  flex-shrink: 0;
  -webkit-mask: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='black' stroke-width='2.2' stroke-linecap='round' stroke-linejoin='round'><polyline points='6 15 12 9 18 15'/></svg>") no-repeat center / contain;
  transition: transform .25s ease;
}
.faq-item.open .faq-arrow {
  transform: rotate(180deg);
}
.faq-answer {
  margin-top: 20rpx;
  font-size: 26rpx;
  color: var(--ink-2);
  line-height: 1.7;
}

/* ============ 反馈表单 ============ */
.feedback-textarea {
  width: 100%;
  box-sizing: border-box;
  padding: 24rpx 26rpx;
  background: var(--bg-card);
  border: 1rpx solid var(--line);
  border-radius: 24rpx;
  font-size: 26rpx;
  color: var(--ink);
  line-height: 1.6;
  min-height: 200rpx;
}
.feedback-placeholder {
  color: var(--ink-4);
  font-size: 26rpx;
}

.feedback-submit {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: var(--ink);
  color: #FFFFFF;
  border: none;
  border-radius: 28rpx;
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
  margin-top: 28rpx;
  padding: 0;
}
.feedback-submit::after {
  border: none;
}

.bottom-spacer {
  height: 48rpx;
}
