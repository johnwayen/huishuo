<!-- 打卡庆祝 ⑤ -->
<view class="page">

  <!-- 飘散彩纸 -->
  <view class="confetti" wx:for="{{confettiList}}" wx:key="i"
        style="top: {{item.top}}%; left: {{item.left}}%; background: {{item.bg}}; transform: rotate({{item.rot}}deg);"></view>

  <view class="celebration-content">
    <view class="celebration-emoji">🎉</view>
    <view class="celebration-title">今日 3 句 全部完成</view>
    <view class="celebration-subtitle">你又坚持了一天，做得很棒</view>

    <view class="streak-display">
      <view class="streak-display-badge">+1 TODAY</view>
      <view class="streak-display-flame">🔥</view>
      <view class="streak-display-num">{{streak.count}}</view>
      <view class="streak-display-label">连续打卡天数</view>
    </view>

    <view class="today-stats-row">
      <view class="today-stat-cell">
        <view class="today-stat-num">{{stats.done}}</view>
        <view class="today-stat-label">已完成</view>
      </view>
      <view class="today-stat-cell">
        <view class="today-stat-num">{{stats.minutes}}<text class="unit">min</text></view>
        <view class="today-stat-label">用时</view>
      </view>
      <view class="today-stat-cell">
        <view class="today-stat-num">{{stats.avgScore}}</view>
        <view class="today-stat-label">平均分</view>
      </view>
    </view>

    <view class="new-formula-badge" wx:if="{{newFormula}}">
      <view class="new-formula-badge-icon">✨</view>
      <view class="new-formula-badge-content">
        <view class="new-formula-badge-label">今日 GET 新公式</view>
        <view class="new-formula-badge-name">{{newFormula}}</view>
      </view>
    </view>
  </view>

  <view class="celebration-actions">
    <button class="celebration-btn-primary" catchtap="onBackHome">明天见 →</button>
    <button class="celebration-btn-share" open-type="share">
      <view class="icon-share"></view>
      <text>分享到朋友圈</text>
    </button>
  </view>

</view>
