/* 我的 ⑥ */

.page {
  width: 100%;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--bg-page);
}

.nav-bar { width: 100%; flex-shrink: 0; }
.nav-bar-content { padding: 0 48rpx; }

.my-page {
  flex: 1;
  padding: 8rpx 40rpx 32rpx;
}

.my-header {
  padding: 16rpx 0 44rpx;
}
.my-greeting-time {
  font-size: 26rpx;
  color: var(--ink-3);
  font-weight: 500;
}
.my-greeting-name {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--ink);
  letter-spacing: -0.6rpx;
  margin-top: 4rpx;
}

.my-stats {
  background: var(--bg-card);
  border: 1rpx solid var(--line);
  border-radius: 36rpx;
  padding: 36rpx 24rpx;
  display: flex;
  gap: 8rpx;
  margin-bottom: 44rpx;
  position: relative;
}
.my-stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 0 8rpx;
  position: relative;
}
.my-stat + .my-stat::before {
  content: '';
  position: absolute;
  left: -4rpx;
  top: 16rpx;
  bottom: 16rpx;
  width: 1rpx;
  background: var(--line);
}
.my-stat-num {
  font-size: 44rpx;
  font-weight: 800;
  color: var(--ink);
  font-variant-numeric: tabular-nums;
  letter-spacing: -1rpx;
  line-height: 1.1;
}
.my-stat-num.is-accent { color: var(--accent); }
.my-stat-label {
  font-size: 20rpx;
  color: var(--ink-3);
  font-weight: 600;
  letter-spacing: 0.6rpx;
  text-align: center;
  white-space: nowrap;
}

.my-section { margin-bottom: 44rpx; }
.my-section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding: 0 4rpx;
}
.my-section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--ink);
  letter-spacing: -0.2rpx;
}

.heatmap-card {
  background: var(--bg-card);
  border: 1rpx solid var(--line);
  border-radius: 32rpx;
  padding: 32rpx 28rpx 24rpx;
}
.heatmap-months {
  display: flex;
  justify-content: space-between;
  font-size: 18rpx;
  color: var(--ink-3);
  font-weight: 600;
  margin-bottom: 12rpx;
  padding: 0 2rpx;
}
.heatmap-grid {
  display: grid;
  grid-template-rows: repeat(7, 1fr);
  grid-auto-flow: column;
  gap: 6rpx;
  margin-bottom: 20rpx;
}
.heatmap-cell {
  aspect-ratio: 1;
  border-radius: 5rpx;
  background: var(--bg-deeper);
}
.heatmap-cell.lvl-1 { background: rgba(255, 107, 82, 0.18); }
.heatmap-cell.lvl-2 { background: rgba(255, 107, 82, 0.40); }
.heatmap-cell.lvl-3 { background: rgba(255, 107, 82, 0.65); }
.heatmap-cell.lvl-4 { background: rgba(255, 107, 82, 0.92); }
.heatmap-legend {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 8rpx;
  font-size: 20rpx;
  color: var(--ink-3);
  font-weight: 500;
}
.legend-cell {
  width: 18rpx;
  height: 18rpx;
  border-radius: 4rpx;
  background: var(--bg-deeper);
}
.legend-cell.lvl-1 { background: rgba(255, 107, 82, 0.18); }
.legend-cell.lvl-2 { background: rgba(255, 107, 82, 0.40); }
.legend-cell.lvl-3 { background: rgba(255, 107, 82, 0.65); }
.legend-cell.lvl-4 { background: rgba(255, 107, 82, 0.92); }

.menu-list {
  background: var(--bg-card);
  border: 1rpx solid var(--line);
  border-radius: 28rpx;
  overflow: hidden;
}
.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid var(--line);
  gap: 24rpx;
}
.menu-item:last-child { border-bottom: none; }
.menu-item:active { background: var(--bg-soft); }
.menu-icon {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--ink-2);
  background: var(--bg-soft);
  border-radius: 16rpx;
}
.ic {
  width: 32rpx;
  height: 32rpx;
  background: currentColor;
}
