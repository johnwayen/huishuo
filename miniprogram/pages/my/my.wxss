}
.menu-label {
  flex: 1;
  font-size: 28rpx;
  color: var(--ink);
  font-weight: 500;
}
.menu-badge {
  font-size: 24rpx;
  color: var(--ink-3);
  font-variant-numeric: tabular-nums;
  margin-right: 12rpx;
}
.menu-arrow {
  font-size: 36rpx;
  color: var(--ink-4);
  font-weight: 300;
  line-height: 1;
}

.my-footer {
  margin-top: 40rpx;
  text-align: center;
  font-size: 22rpx;
  color: var(--ink-4);
  letter-spacing: 0.6rpx;
  line-height: 1.6;
  padding-bottom: 24rpx;
}
