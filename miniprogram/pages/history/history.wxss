/* 学习记录 ⑩ */

.page {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--bg-page);
}

/* ============ 自定义导航栏 ============ */
.nav-bar { width: 100%; flex-shrink: 0; }
.nav-bar-content {
  display: flex;
  align-items: center;
  padding: 0 48rpx;
  justify-content: space-between;
}
.nav-back {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--ink);
  background: transparent;
}
.back-icon {
  width: 44rpx;
  height: 44rpx;
  background: currentColor;
  -webkit-mask: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='black' stroke-width='2.2' stroke-linecap='round' stroke-linejoin='round'><polyline points='15 18 9 12 15 6'/></svg>") no-repeat center / contain;
}
.nav-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--ink-2);
}

/* ============ 列表滚动容器 ============ */
.subpage-list {
  flex: 1;
  padding: 8rpx 48rpx 48rpx;
  box-sizing: border-box;
}

/* ============ Filter pills ============ */
.subpage-filter-bar {
  display: flex;
  gap: 16rpx;
  padding: 8rpx 0 28rpx;
  flex-wrap: nowrap;
}
.filter-pill {
  padding: 14rpx 28rpx;
  border-radius: 200rpx;
  background: var(--bg-card);
  border: 1rpx solid var(--line);
  font-size: 24rpx;
  font-weight: 600;
  color: var(--ink-3);
  white-space: nowrap;
  flex-shrink: 0;
  transition: background .2s, color .2s, border-color .2s;
}
.filter-pill.active {
  background: var(--ink);
  color: #FFFFFF;
  border-color: var(--ink);
}

/* ============ Timeline item ============ */
.timeline-item {
  background: var(--bg-card);
  border: 1rpx solid var(--line);
  border-radius: 28rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
}
.timeline-date {
  font-size: 24rpx;
  color: var(--ink-2);
  font-weight: 700;
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.timeline-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: var(--accent);
  flex-shrink: 0;
}
.timeline-dot.missed {
  background: var(--ink-4);
}
.timeline-summary {
  font-size: 26rpx;
  color: var(--ink);
  font-weight: 500;
  line-height: 1.5;
}
.timeline-item.missed .timeline-summary {
  color: var(--ink-3);
}
.timeline-stats {
  display: flex;
  gap: 32rpx;
  margin-top: 16rpx;
}
.timeline-stat {
  font-size: 22rpx;
  color: var(--ink-3);
}
.timeline-stat .stat-b {
  color: var(--ink);
  font-weight: 700;
}

.list-bottom-pad {
  height: 32rpx;
}
